# ============================================================
# R / RStudio
# ============================================================
.Rhistory
.RData
.Ruserdata
.Rproj.user/
*.Rproj.user

# ============================================================
# Operating system files
# ============================================================
.DS_Store
Thumbs.db
desktop.ini

# ============================================================
# Temporary Office files
# ============================================================
~$*.docx
~$*.xlsx
~$*.pptx

# ============================================================
# Local credentials and environment files
# ============================================================
.Renviron
.env
*.key
*.pem
*.p12

# ============================================================
# Local data and metadata: never commit
# ============================================================
# This includes raw Add Health data, processed data, local metadata,
# codebooks, thesis reference material and any local data documentation.
data/**

# ============================================================
# Local analytical objects and logs
# ============================================================
outputs/analysis/**
outputs/logs/**
outputs/constructs/**
outputs/indices/**
outputs/models/**

# ============================================================
# Local audit outputs
# ============================================================
# Audit files are local by default. Add selected public audit
# summaries explicitly only when needed, using git add -f.
outputs/audits/**

# Exception: Script 20 metadata checklist may be committed.
!outputs/audits/script20_repository_metadata_update_checklist.csv

# ============================================================
# Large or local-only binary artefacts
# ============================================================
*.zip
*.7z
*.tar
*.tar.gz
*.gz

# ============================================================
# Repository maintenance backups
# ============================================================
docs/metadata_backups/**

# ============================================================
# Keep selected public outputs and reports trackable
# ============================================================
# The following folders are intentionally not ignored:
# - R/
# - docs/
# - outputs/tables/
# - outputs/reports/
#
# Do not use git add . in this repository.
# Add files explicitly to avoid committing sensitive or local-only materials.